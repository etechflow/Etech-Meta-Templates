<?xml version="1.0"?>
<!--
/**
 * Update notice: when the admin opens the Meta Templates admin area, surface a bell
 * notification if a newer module version is published to the eTechFlow Composer repo.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="controller_action_predispatch_metatemplates">
        <observer name="etechflow_metatemplates_update_notification" instance="Etechflow\MetaTemplates\Observer\AddUpdateNotification"/>
    </event>
</config>
