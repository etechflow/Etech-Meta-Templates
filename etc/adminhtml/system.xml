<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="400">
            <label>Etechflow</label>
        </tab>
        <section id="etechflow_metatemplates" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Meta Templates</label>
            <tab>etechflow</tab>
            <resource>Etechflow_MetaTemplates::config</resource>

            <group id="module_status" translate="label" type="text" sortOrder="0" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Module Status</label>
                <frontend_model>Etechflow\MetaTemplates\Block\Adminhtml\System\Config\ModuleStatus</frontend_model>
            </group>
            <group id="license" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>
                <field id="license_key" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <comment><![CDATA[
                        Paste the SP-XXXX key from your purchase email, or a per-module HMAC key, or a
                        shared eTechFlow bundle key. Bound to the domain you provided at checkout.<br/>
                        A valid licence is always required. <code>www.</code> prefix is normalised.
                    ]]></comment>
                </field>
                <field id="bundle_license_key" translate="label comment" type="obscure" sortOrder="15" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Bundle License Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <config_path>etechflow_bundle/license/license_key</config_path>
                    <comment><![CDATA[
                        Shared key across ALL eTechFlow modules. If you purchased the eTechFlow Bundle,
                        paste it here once and every installed eTechFlow module activates.<br/>
                        Stored encrypted.
                    ]]></comment>
                </field>
                <field id="portal_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL</label>
                    <comment><![CDATA[
                        The eTechFlow portal endpoint that validates SP-XXXX subscription keys.
                        Default: <code>https://license-service.etechflow.com/license/validate</code>.
                        Change only if eTechFlow notifies you of a new portal URL.
                    ]]></comment>
                </field>
                <field id="issued_key" translate="label" type="obscure" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Last Issued Key (auto-managed)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[
                        Read-only audit field. Auto-populated when the portal accepts a key for the first time.
                        Used by the module to auto-restore the licence after a portal IP-block lift.
                        Do not edit manually.
                    ]]></comment>
                </field>
            </group>

            <group id="payment" translate="label" type="text" sortOrder="5" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Payment (Stripe)</label>
                <field id="stripe_secret_key" translate="label comment" type="obscure" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Stripe Secret Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[
                        Your Stripe <code>sk_test_...</code> (test mode) or <code>sk_live_...</code> (live).
                        Used to create the Checkout Session when a merchant clicks Pay on the gate page.
                        Stored encrypted.
                    ]]></comment>
                </field>
                <field id="stripe_publishable_key" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Stripe Publishable Key</label>
                    <comment><![CDATA[
                        Your Stripe <code>pk_test_...</code> or <code>pk_live_...</code> key.
                    ]]></comment>
                </field>
                <field id="stripe_currency" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Currency</label>
                    <comment><![CDATA[
                        Three-letter Stripe currency code, lowercase. Default: <code>usd</code>.
                    ]]></comment>
                </field>
            </group>

            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label tooltip" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Meta Templates</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <tooltip>Master switch. When OFF, no templates are applied.</tooltip>
                </field>
                <field id="mode" translate="label comment tooltip" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Apply mode</label>
                    <source_model>Etechflow\MetaTemplates\Model\Config\Source\Mode</source_model>
                    <comment>Fill-empty respects manually set product/category meta; Override always wins.</comment>
                    <tooltip>"Only fill empty" never overwrites meta a product/category already has. "Always override" applies the template everywhere.</tooltip>
                </field>
            </group>
            <group id="variables" translate="label" type="text" sortOrder="20" showInDefault="1">
                <label>Available variables</label>
                <comment><![CDATA[Use these in your templates (optional fallback: <b>{{var|fallback}}</b>):<br/>
                    <b>Product:</b> {{product.name}}, {{product.sku}}, {{product.price}}, {{product.brand}}, {{product.category}}, {{product.&lt;attribute_code&gt;}}<br/>
                    <b>Category:</b> {{category.name}}, {{category.description}}<br/>
                    <b>CMS:</b> {{cms.title}} &nbsp; <b>Store:</b> {{store.name}}, {{store.url}}]]></comment>
            </group>
        </section>
    </system>
</config>
